<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <input>
    <net-file value="plaza.net.xml"/>
    <route-files value="out/plaza.baseline.sampled.rou.xml"/>
    <additional-files value="plaza.vtypes.xml"/>
  </input>
  <time>
    <begin value="0"/>
    <end value="720"/>
    <step-length value="1.0"/>
  </time>
  <output>
    <fcd-output value="out/baseline.fcd.xml"/>
    <tripinfo-output value="out/baseline.tripinfo.xml"/>
  </output>
  <processing>
    <time-to-teleport value="120"/>
  </processing>
</configuration>
